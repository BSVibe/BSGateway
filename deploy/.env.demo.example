# BSGateway DEMO environment template (deploy/.env.demo).
#
# Copy to `deploy/.env.demo` and fill in real values. `.env.demo` is gitignored.
# This file configures the PUBLIC INTERACTIVE DEMO stack — separate from prod.
#
# Generate secrets:
#   openssl rand -hex 32      # for DEMO_JWT_SECRET
#   openssl rand -base64 32   # for POSTGRES_PASSWORD, REDIS_PASSWORD

# ─── Demo session signing (per-product, NOT shared with prod auth.bsvibe.dev) ───
# This signs the JWT issued by POST /api/v1/demo/session. NEVER reuse prod JWT secret.
DEMO_JWT_SECRET=

# ─── LiteLLM (mock mode for demo) ───
# In demo mode, LLM calls are intercepted and return mock_response. Real key not required.
LITELLM_MASTER_KEY=demo-master-key-not-used
LOCAL_LLM_API_BASE=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Database (isolated demo PG) ───
POSTGRES_USER=bsgateway_demo
POSTGRES_PASSWORD=
POSTGRES_DB=bsgateway_demo

# ─── Redis (isolated demo) ───
REDIS_PASSWORD=

# ─── CORS — demo frontend domain only ───
CORS_ORIGINS=["https://demo-gateway.bsvibe.dev"]

# ─── Logging ───
LOG_LEVEL=INFO
