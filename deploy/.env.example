# =============================================================================
# BSGateway Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!
# =============================================================================

# ── LiteLLM Gateway ────────────────────────────────────────────
LITELLM_MASTER_KEY=<generate-with-openssl-rand-hex-32>

# ── Local LLM (Ollama or compatible) ───────────────────────────
LOCAL_LLM_API_BASE=http://host.docker.internal:11434

# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Infrastructure: PostgreSQL ─────────────────────────────────
POSTGRES_USER=bsgateway
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=bsgateway
COLLECTOR_DATABASE_URL=postgresql://bsgateway:<password>@postgres:5432/bsgateway

# ── Infrastructure: Redis ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication (BSVibe-Auth) ──────────────────────────────
# BSVibe Auth URL (default: https://auth.bsvibe.dev — only override for self-hosted)
BSVIBE_AUTH_URL=https://auth.bsvibe.dev
ENCRYPTION_KEY=<64-hex-chars-generate-with-openssl-rand-hex-32>

# ── Token introspection (RFC 7662) ─────────────────────────────
# REQUIRED in prod — without these three, the gateway can only verify
# user JWTs (not opaque ``bsv_sk_*`` PATs and not the HS256 PAT JWTs
# the device-flow grant emits). Phase 8 dogfood (2026-05-11) caught
# four products silently 401'ing because these were never set.
#
# 1. Provision a row in BSVibe-Auth's ``oauth_clients`` for this
#    backend (e.g. ``bsgateway-prod`` confidential client). The raw
#    secret is shown once at creation; store it in Vaultwarden.
# 2. Set the three vars below from that row.
#
# Both ``UNPREFIXED`` and ``BSV_PREFIXED`` names work (Wave 3 added
# AliasChoices in core/config.py).
INTROSPECTION_URL=https://auth.bsvibe.dev/api/tokens/introspect
INTROSPECTION_CLIENT_ID=bsgateway-prod
INTROSPECTION_CLIENT_SECRET=<64-hex-from-oauth_clients-issue>

# Optional — emergency bootstrap admin token's SHA-256. Prod normally
# leaves this unset; introspection covers all real traffic.
# BOOTSTRAP_TOKEN_HASH=<sha256-of-bsv_admin_*>

# ── Server ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=
